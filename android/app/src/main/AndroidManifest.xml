<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.OutlinerGod">

        <!-- namespace = com.outlinegod.app, class is com.outlinegod.app.MainActivity -->
        <activity
            android:name="com.outlinegod.app.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- class is com.outlinegod.prototype.DndPrototypeActivity; exported for ADB testing -->
        <activity
            android:name="com.outlinegod.prototype.DndPrototypeActivity"
            android:exported="true"
            android:label="DnD Prototype" />

        <!-- class is com.outlinegod.prototype.WysiwygPrototypeActivity; exported for ADB testing -->
        <activity
            android:name="com.outlinegod.prototype.WysiwygPrototypeActivity"
            android:exported="true"
            android:label="WYSIWYG Prototype" />

    </application>

</manifest>
