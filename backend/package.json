{
  "name": "outlinergod-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "migrate:generate": "node --require tsx/cjs node_modules/drizzle-kit/bin.cjs generate",
    "migrate:run": "drizzle-kit migrate",
    "dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.4",
    "@fastify/type-provider-typebox": "^4.0.0",
    "better-sqlite3": "12.6.2",
    "drizzle-orm": "0.45.1",
    "fastify": "5.7.4",
    "fastify-plugin": "^5.0.1",
    "google-auth-library": "10.6.1",
    "jose": "6.1.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
