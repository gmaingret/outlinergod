# Path inside the container where the SQLite database is stored
DATABASE_PATH=/data/outlinegod.db

# JWT signing secret — must be at least 32 random bytes, hex-encoded
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Google OAuth 2.0 Web client ID (used to verify ID tokens from the Android app)
GOOGLE_CLIENT_ID=

# Port the Fastify server listens on inside the container
PORT=3000

# Path inside the container where uploaded files are stored
UPLOADS_PATH=/data/uploads

# Maximum allowed upload size in bytes (default 50 MB)
MAX_UPLOAD_BYTES=52428800
